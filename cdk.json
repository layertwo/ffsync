{
    "app": "npx ts-node --prefer-ts-exts lib/app",
    "profile": "ffsync",
    "watch": {
        "include": [
            "**"
        ],
        "exclude": [
            "README.md",
            "cdk*.json",
            "**/*.d.ts",
            "**/*.js",
            "tsconfig.json",
            "package*.json",
            "yarn.lock",
            "node_modules",
            "test",
            "build"
        ]
    },
    "context": {
        "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true,
        "@aws-cdk/aws-iam:enablePartitionalLiterals": true,
        "@aws-cdk/aws-iam:minimizePolicies": true
    },
    "output": "build/cdk.out"
}
