{
    "version": "1.0",
    "sources": ["models"],
    "maven": {
        "dependencies": [
            "software.amazon.smithy:smithy-aws-traits:1.65.0",
            "software.amazon.smithy:smithy-aws-apigateway-traits:1.66.0",
            "software.amazon.smithy:smithy-validation-model:1.65.0",
            "software.amazon.smithy:smithy-openapi:1.65.0",
            "software.amazon.smithy:smithy-aws-apigateway-openapi:1.65.0"
        ]
    },
    "projections": {
        "storage": {
            "plugins": {
                "openapi": {
                    "service": "layertwo.ffsync#StorageService",
                    "protocol": "aws.protocols#restJson1",
                    "version": "3.0.2",
                    "apiGatewayType": "REST",
                    "disableCloudFormationSubstitution": true
                }
            }
        },
        "token": {
            "plugins": {
                "openapi": {
                    "service": "layertwo.ffsync#TokenService",
                    "protocol": "aws.protocols#restJson1",
                    "version": "3.0.2",
                    "apiGatewayType": "REST",
                    "disableCloudFormationSubstitution": true
                }
            }
        }
    }
}
