{
    "version": "1.0",
    "sources": ["models"],
    "projections": {
        "storage": {
            "plugins": {
                "openapi": {
                    "service": "layertwo.ffsync#StorageService",
                    "protocol": "aws.protocols#restJson1",
                    "version": "3.0.2",
                    "apiGatewayType": "REST",
                    "disableCloudFormationSubstitution": true,
                    "useIntegerType": true
                }
            }
        },
        "auth": {
            "plugins": {
                "openapi": {
                    "service": "layertwo.ffsync#AuthService",
                    "protocol": "aws.protocols#restJson1",
                    "version": "3.0.2",
                    "apiGatewayType": "REST",
                    "disableCloudFormationSubstitution": true,
                    "useIntegerType": true
                }
            }
        },
        "token": {
            "plugins": {
                "openapi": {
                    "service": "layertwo.ffsync#TokenService",
                    "protocol": "aws.protocols#restJson1",
                    "version": "3.0.2",
                    "apiGatewayType": "REST",
                    "disableCloudFormationSubstitution": true,
                    "useIntegerType": true
                }
            }
        },
        "profile": {
            "plugins": {
                "openapi": {
                    "service": "layertwo.ffsync#ProfileService",
                    "protocol": "aws.protocols#restJson1",
                    "version": "3.0.2",
                    "apiGatewayType": "REST",
                    "disableCloudFormationSubstitution": true,
                    "useIntegerType": true
                }
            }
        }
    }
}
