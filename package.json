{
    "name": "@layertwo/ffsync",
    "version": "0.1.0",
    "scripts": {
        "build": "tsc",
        "cdk": "cdk",
        "check-format": "eslint lib package.json eslint.config.mjs .prettierrc.js",
        "clean": "find lib \\( -name \"*.d.ts\" -o -name \"*.js\" \\) -delete",
        "format": "npm run check-format -- --fix",
        "test": "jest",
        "watch": "tsc -w"
    },
    "dependencies": {
        "@aws-cdk/aws-lambda-python-alpha": "^2.231.0-alpha.0",
        "aws-cdk": "^2.1033.0",
        "aws-cdk-lib": "^2.231.0",
        "cdk-monitoring-constructs": "^9.16.0",
        "change-case": "^5.4.4",
        "constructs": "^10.4.2",
        "env-var": "^7.0.0",
        "source-map-support": "^0.5.16"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin-js": "^4.0.0",
        "@trivago/prettier-plugin-sort-imports": "^6.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "*",
        "@typescript-eslint/eslint-plugin": "^8.18.0",
        "@typescript-eslint/parser": "^8.18.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^30.0.4",
        "prettier": "^3.2.5",
        "prettier-plugin-pkgsort": "^0.2.1",
        "ts-jest": "^29.4.0",
        "ts-node": "^10.9.2",
        "typescript": "~5.9.0"
    }
}
