{
    "name": "@layertwo/ffsync",
    "version": "0.1.0",
    "scripts": {
        "build": "tsc",
        "cdk": "cdk",
        "check-format": "eslint lib package.json eslint.config.mjs .prettierrc.mjs",
        "clean": "find lib \\( -name \"*.d.ts\" -o -name \"*.js\" \\) -delete",
        "format": "npm run check-format -- --fix",
        "test": "jest",
        "watch": "tsc -w"
    },
    "dependencies": {
        "uv-python-lambda": "^0.0.7",
        "aws-cdk": "^2.1120.0",
        "aws-cdk-lib": "^2.252.0",
        "cdk-monitoring-constructs": "^10.0.0",
        "constructs": "^10.6.0",
        "env-var": "^7.5.0",
        "source-map-support": "^0.5.21"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin-js": "^4.4.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "*",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "prettier-plugin-pkgsort": "^0.3.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "~5.9.3"
    }
}
